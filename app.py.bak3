    transition: all 0.15s;
  }
  .url-add-btn:hover { border-color: var(--accent2); color: var(--accent2); }

  .file-upload-area {
    border: 1px dashed var(--border); border-radius: 6px;
    padding: 14px; text-align: center; cursor: pointer;
    margin-bottom: 12px; transition: all 0.15s;
    font-family: var(--mono); font-size: 11px; color: var(--muted);
  }
  .file-upload-area:hover { border-color: var(--accent2); color: var(--accent2); }
  .file-upload-area.dragover { border-color: var(--accent); background: rgba(232,68,26,0.05); }
  #file-input { display: none; }
  #file-list { font-family: var(--mono); font-size: 10px; color: var(--green); margin-bottom: 8px; }

  .modal-footer { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
  .modal-btn {
    padding: 8px 18px; border-radius: 6px;
    font-family: var(--mono); font-size: 12px; cursor: pointer;
    transition: all 0.15s; border: 1px solid var(--border);
  }
  .modal-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .modal-btn.primary:hover { opacity: 0.88; }
  .modal-btn.secondary { background: transparent; color: var(--muted); }
  .modal-btn.secondary:hover { color: var(--text); }

  /* 토스트 */
  .toast {
    position: fixed; bottom: 24px; right: 24px;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 16px;
    font-size: 12px; font-family: var(--mono);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    opacity: 0; transform: translateY(6px);
    transition: all 0.2s; z-index: 999; pointer-events: none;
  }
  .toast.show { opacity: 1; transform: translateY(0); }
  .toast.success { border-color: var(--green); color: var(--green); }
  .toast.error   { border-color: #ff6b6b; color: #ff6b6b; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-text"><span>Dev</span>Trace</div>
    <div class="logo-sub">개발 과정 자동 기록 시스템</div>
  </div>
  <div class="header-right">
    <div class="api-toggle">
      <button id="btn-groq" class="active" onclick="setApi('groq')">Groq</button>
      <button id="btn-openai" onclick="setApi('openai')">OpenAI</button>
    </div>
    <div style="display:flex;align-items:center;gap:6px;">
      <div class="status-dot"></div>
      <span class="status-label">v2.11</span>
    </div>
  </div>
</header>

<div class="layout">

  <!-- 사이드바 -->
  <nav class="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-label">일지</div>
      <button class="cmd-btn active" onclick="selectCmd(this,'daily')">
        <span class="cmd-icon">📅</span>
        <div class="cmd-info"><div class="cmd-name">daily</div><div class="cmd-desc">오늘 일지 생성</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'weekly')">
        <span class="cmd-icon">📊</span>
        <div class="cmd-info"><div class="cmd-name">weekly</div><div class="cmd-desc">주간 리포트 생성</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'full')">
        <span class="cmd-icon">📚</span>
        <div class="cmd-info"><div class="cmd-name">full</div><div class="cmd-desc">전체 히스토리 요약</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'range')">
        <span class="cmd-icon">📅</span>
        <div class="cmd-info"><div class="cmd-name">range</div><div class="cmd-desc">날짜 범위 분석</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'regenerate')">
        <span class="cmd-icon">🔄</span>
        <div class="cmd-info"><div class="cmd-name">regenerate</div><div class="cmd-desc">AI만 재호출</div></div>
      </button>
    </div>

    <hr class="sidebar-divider">

    <div class="sidebar-section">
      <div class="sidebar-label">프로젝트</div>
      <button class="cmd-btn" onclick="selectCmd(this,'project')">
        <span class="cmd-icon">🔍</span>
        <div class="cmd-info"><div class="cmd-name">project</div><div class="cmd-desc">프로젝트 단위 분석</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'portfolio')">
        <span class="cmd-icon">🏗</span>
        <div class="cmd-info"><div class="cmd-name">portfolio</div><div class="cmd-desc">GitHub README 생성</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'interview')">
        <span class="cmd-icon">🎤</span>
        <div class="cmd-info"><div class="cmd-name">interview</div><div class="cmd-desc">면접 질문 생성</div></div>
      </button>
    </div>

    <hr class="sidebar-divider">

    <div class="sidebar-section">
      <div class="sidebar-label">시스템</div>
      <button class="cmd-btn" onclick="selectCmd(this,'push')">
        <span class="cmd-icon">📤</span>
        <div class="cmd-info"><div class="cmd-name">push</div><div class="cmd-desc">GitHub push</div></div>
      </button>
      <button class="cmd-btn" onclick="selectCmd(this,'status')">
        <span class="cmd-icon">⚙️</span>
        <div class="cmd-info"><div class="cmd-name">status</div><div class="cmd-desc">데몬 상태 확인</div></div>
      </button>
    </div>
  </nav>

  <!-- 메인 -->
  <main>
    <div class="control-bar">
      <div class="control-left">
        <div class="main-title" id="main-title">daily — 오늘 일지 생성</div>
        <div class="main-cmd" id="main-cmd">$ bash devtrace.sh daily</div>
      </div>
      <div class="control-right" id="control-right">
        <button class="run-btn" id="run-btn" onclick="runCommand()">
          <div class="spinner"></div>
          <span class="btn-text">▶ 실행</span>
        </button>
      </div>
    </div>

    <div class="content-area">

      <!-- 로그 터미널 -->
      <div class="log-wrap">
        <div class="terminal-bar">
          <div class="dot dot-r"></div>
          <div class="dot dot-y"></div>
          <div class="dot dot-g"></div>
          <span class="terminal-title" id="terminal-title">대기 중</span>
          <button class="clear-btn" onclick="clearLog()">clear</button>
        </div>
        <div id="terminal">
          <span style="color:#444;font-family:var(--mono);font-size:11px;">실행 로그가 여기에 표시됩니다</span>
        </div>
      </div>

      <!-- 결과 뷰어 -->
      <div class="result-wrap">
        <div class="result-header">
          <span class="result-title">RESULT</span>
          <span class="result-name" id="result-name">—</span>
        </div>
        <div id="result-view">
          <div class="result-empty">
            <div class="ei">📄</div>
            <p>실행 후 결과물이 여기에 표시됩니다</p>
          </div>
        </div>
        <textarea id="edit-view" spellcheck="false"></textarea>

        <!-- 하단 액션 버튼 바 -->
        <div class="action-bar">
          <button class="action-btn" id="btn-edit" onclick="startEdit()" disabled>✏️ 편집</button>
          <button class="action-btn save-btn" id="btn-save" onclick="saveEdit()">💾 저장</button>
          <button class="action-btn cancel-btn" id="btn-cancel" onclick="cancelEdit()">✕ 취소</button>
          <button class="action-btn" id="btn-ref" onclick="openRefModal()" disabled>📚 참고자료</button>
          <button class="action-btn" id="btn-regen" onclick="regenCurrent()" disabled>🔄 재생성</button>
        </div>
      </div>

    </div>
  </main>

  <!-- 오른쪽 패널 -->
  <div class="right-panel">
    <div class="panel-header">저장된 파일</div>
    <div class="journal-list" id="journal-list">
      {% if journals %}
        {% for j in journals %}
        <div class="journal-item" onclick="loadJournal('{{ j.path }}', '{{ j.name }}', this)">
          <div class="journal-dot"></div>
          <div class="journal-date" title="{{ j.name }}">{{ j.name }}</div>
          <div class="journal-size">{{ (j.size / 1024) | round(1) }}KB</div>
        </div>
        {% endfor %}
      {% else %}
        <div style="padding:16px 18px;font-size:11px;color:var(--muted);font-family:var(--mono);">파일 없음</div>
      {% endif %}
    </div>
  </div>

</div>

<!-- 참고자료 모달 -->
<div class="modal-overlay" id="ref-modal">
  <div class="modal">
    <div class="modal-title">📚 참고자료 추가</div>

    <span class="modal-label">URL</span>
    <div class="url-list" id="url-list">
      <div class="url-row">
        <input class="modal-input" type="text" placeholder="https://" />
        <button class="url-del-btn" onclick="removeUrl(this)">✕</button>
      </div>
    </div>
    <button class="url-add-btn" onclick="addUrl()">+ URL 추가</button>

    <span class="modal-label">파일 첨부</span>
    <div class="file-upload-area" onclick="document.getElementById('file-input').click()"
         ondragover="event.preventDefault();this.classList.add('dragover')"
         ondragleave="this.classList.remove('dragover')"
         ondrop="handleFileDrop(event)">
      📂 클릭하거나 파일을 여기로 드래그하세요
    </div>
    <input type="file" id="file-input" multiple onchange="handleFileSelect(this)">
    <div id="file-list"></div>

    <div class="modal-footer">
      <button class="modal-btn secondary" onclick="closeRefModal()">취소</button>
      <button class="modal-btn primary" onclick="submitRef()">저장</button>
    </div>
  </div>
</div>

<!-- 템플릿 추가 모달 -->
<div class="modal-overlay" id="tmpl-modal">
  <div class="modal">
    <div class="modal-title">📝 커스텀 템플릿 추가</div>
    <span class="modal-label">템플릿 이름</span>
    <input class="modal-input" id="tmpl-name-input" type="text" placeholder="예: wanted, notion, simple" />
    <span class="modal-label">템플릿 내용 (마크다운)</span>
    <textarea class="modal-textarea" id="tmpl-content-input" placeholder="템플릿 내용을 입력하세요"></textarea>
    <div class="modal-footer">
      <button class="modal-btn secondary" onclick="closeTmplModal()">취소</button>
      <button class="modal-btn primary" onclick="submitTemplate()">저장</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let currentCmd = 'daily';
let currentApi = 'groq';
let isRunning = false;
let currentFilePath = null;
let currentFileName = null;
let selectedFiles = [];

const CMD_META = {
  daily:      { title: 'daily — 오늘 일지 생성',        cmd: '$ bash devtrace.sh daily',             inputs: [] },
  weekly:     { title: 'weekly — 주간 리포트',           cmd: '$ bash devtrace.sh weekly',            inputs: [] },
  full:       { title: 'full — 전체 히스토리 요약',      cmd: '$ bash devtrace.sh full',              inputs: [] },
  range:      { title: 'range — 날짜 범위 분석',         cmd: '$ bash devtrace.sh range <from> <to>', inputs: ['from','to'] },
  regenerate: { title: 'regenerate — AI 재호출',         cmd: '$ bash devtrace.sh regenerate <날짜>', inputs: ['date'] },
  project:    { title: 'project — 프로젝트 분석',        cmd: '$ bash devtrace.sh project <이름>',    inputs: ['project'] },
  portfolio:  { title: 'portfolio — GitHub README 생성', cmd: '$ bash devtrace.sh portfolio <이름>',  inputs: ['project', 'template'] },
  interview:  { title: 'interview — 면접 질문 생성',     cmd: '$ bash devtrace.sh interview <이름>',  inputs: ['project'] },
  push:       { title: 'push — GitHub push',             cmd: '$ bash devtrace.sh push',              inputs: [] },
  status:     { title: 'status — 데몬 상태 확인',        cmd: '$ bash devtrace.sh status',            inputs: [] },
};

const INPUT_CONFIG = {
  project:  { label: '프로젝트', placeholder: '프로젝트 이름', type: 'project', cls: '' },
  from:     { label: 'from',     placeholder: '2026-06-01',    type: 'date',    cls: 'short' },
  to:       { label: 'to',       placeholder: '2026-06-14',    type: 'date',    cls: 'short' },
  date:     { label: '날짜',     placeholder: '2026-06-14',    type: 'date',    cls: 'short' },
  template: { label: '템플릿',   placeholder: '',              type: 'select',  cls: '' },
};

const PROJECTS = {{ projects | tojson }};
let TEMPLATES = {{ templates | tojson }};

// ── API 토글 ──────────────────────────────────────
function setApi(api) {
  currentApi = api;
  document.getElementById('btn-groq').classList.toggle('active', api === 'groq');
  document.getElementById('btn-openai').classList.toggle('active', api === 'openai');
  showToast(api === 'groq' ? 'Groq (llama-3.3-70b)' : 'OpenAI (gpt-4o-mini)', 'success');
}

// ── 입력칸 렌더링 ─────────────────────────────────
function renderInputs(inputs) {
  const cr = document.getElementById('control-right');
  const btn = document.getElementById('run-btn');
  while (cr.firstChild && cr.firstChild !== btn) cr.removeChild(cr.firstChild);

  inputs.forEach(key => {
    const cfg = INPUT_CONFIG[key];
    const wrap = document.createElement('div');
    wrap.className = 'input-wrap';

    const label = document.createElement('span');
    label.className = 'input-label';
    label.textContent = cfg.label + ':';
    wrap.appendChild(label);

    if (cfg.type === 'select') {
      // 템플릿 드롭다운
      const sel = document.createElement('select');
      sel.className = 'cmd-select';
      sel.id = 'input-' + key;
      TEMPLATES.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t;
        opt.textContent = t;
        sel.appendChild(opt);
      });
      // + 커스텀 추가 버튼
      const addBtn = document.createElement('button');
      addBtn.className = 'action-btn';
      addBtn.style.cssText = 'padding:6px 10px;font-size:11px;';
      addBtn.textContent = '+ 추가';
      addBtn.onclick = openTmplModal;
      wrap.appendChild(sel);
      wrap.appendChild(addBtn);
    } else {
      const inp = document.createElement('input');
      inp.type = 'text';
      inp.className = 'cmd-input ' + cfg.cls;
      inp.placeholder = cfg.placeholder;
      inp.id = 'input-' + key;
      inp.addEventListener('keydown', e => { if (e.key === 'Enter') runCommand(); });

      if (cfg.type === 'project' && PROJECTS.length > 0) {
        const dl = document.createElement('datalist');
        dl.id = 'dl-project';
        PROJECTS.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p;
          dl.appendChild(opt);
        });
        document.body.appendChild(dl);
        inp.setAttribute('list', 'dl-project');
      }
      if (cfg.type === 'date') {
        inp.value = new Date().toISOString().slice(0, 10);
      }
      wrap.appendChild(inp);
    }

    cr.insertBefore(wrap, btn);
  });
}

function getInputVal(key) {
  const el = document.getElementById('input-' + key);
  return el ? el.value.trim() : '';
}

// ── 사이드바 선택 ─────────────────────────────────
function selectCmd(el, cmd) {
  document.querySelectorAll('.cmd-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  currentCmd = cmd;
  const m = CMD_META[cmd];
  document.getElementById('main-title').textContent = m.title;
  document.getElementById('main-cmd').textContent = m.cmd;
  renderInputs(m.inputs);
}

// ── 로그 터미널 ───────────────────────────────────
function clearLog() {
  document.getElementById('terminal').innerHTML =
    '<span style="color:#444;font-family:var(--mono);font-size:11px;">실행 로그가 여기에 표시됩니다</span>';
  document.getElementById('terminal-title').textContent = '대기 중';
}

function appendLine(text, cls) {
  const t = document.getElementById('terminal');
  if (t.querySelector('span')) t.innerHTML = '';
  const div = document.createElement('div');
  div.className = cls || 'line-plain';
  div.textContent = text;
  t.appendChild(div);
  t.scrollTop = t.scrollHeight;
}

function classifyLine(line) {
  if (!line) return 'line-plain';
  if (line.startsWith('✅') || line.startsWith('📖') || line.startsWith('📊')) return 'line-ok';
  if (line.startsWith('❌') || line.startsWith('⚠️')) return 'line-err';
  if (line.match(/^[📡🔄📝🗓📚🏗🎤📤🔍⏳[]/)) return 'line-info';
  if (line.startsWith('$')) return 'line-cmd';
  return 'line-plain';
}

// ── 결과 뷰어 ─────────────────────────────────────
function showResult(content, name, path) {
  const rv = document.getElementById('result-view');
  rv.innerHTML = '';
  rv.textContent = content;
  document.getElementById('result-name').textContent = name || '—';
  currentFilePath = path || null;
  currentFileName = name || null;

  // 액션 버튼 활성화
  const hasFile = !!path;
  document.getElementById('btn-edit').disabled = !hasFile;
  document.getElementById('btn-ref').disabled = !hasFile;
  document.getElementById('btn-regen').disabled = !hasFile;
}

// ── 편집 기능 ─────────────────────────────────────
function startEdit() {
  const rv = document.getElementById('result-view');
  const ev = document.getElementById('edit-view');
  ev.value = rv.textContent;
  rv.style.display = 'none';
  ev.style.display = 'block';
  ev.focus();

  document.getElementById('btn-edit').style.display = 'none';
  document.getElementById('btn-save').style.display = 'flex';
  document.getElementById('btn-cancel').style.display = 'flex';
  document.getElementById('btn-ref').disabled = true;
  document.getElementById('btn-regen').disabled = true;
}

function cancelEdit() {
  exitEditMode();
}

function exitEditMode() {
  const rv = document.getElementById('result-view');
  const ev = document.getElementById('edit-view');
  rv.style.display = 'block';
  ev.style.display = 'none';
  document.getElementById('btn-edit').style.display = 'flex';
  document.getElementById('btn-save').style.display = 'none';
  document.getElementById('btn-cancel').style.display = 'none';
  document.getElementById('btn-ref').disabled = false;
  document.getElementById('btn-regen').disabled = false;
}

async function saveEdit() {
  if (!currentFilePath) return;
  const content = document.getElementById('edit-view').value;
  try {
    const res = await fetch('/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path: currentFilePath, content })
    });
    const data = await res.json();
    if (data.ok) {
      document.getElementById('result-view').textContent = content;
      exitEditMode();
      showToast('✅ 저장 완료', 'success');
    } else {
      showToast('❌ 저장 실패: ' + data.error, 'error');
    }
  } catch(e) {
    showToast('❌ 오류: ' + e.message, 'error');
  }
}

// ── 재생성 ────────────────────────────────────────
async function regenCurrent() {
  if (!currentFileName) return;

  // 파일명 패턴으로 커맨드/인자 자동 판단
  let cmd, params;
  const dateMatch   = currentFileName.match(/^(\d{4}-\d{2}-\d{2})$/);
  const projectMatch = currentFileName.match(/^project_(.+)$/);
  const readmeMatch  = currentFileName.match(/^(.+)_README$/);
  const interviewMatch = currentFileName.match(/^(.+)_interview$/);

  if (dateMatch) {
    cmd = 'regenerate';
    params = new URLSearchParams({ cmd, api: currentApi, date: dateMatch[1] });
    appendLine('$ bash devtrace.sh regenerate ' + dateMatch[1], 'line-cmd');
  } else if (projectMatch) {
    cmd = 'project';
    params = new URLSearchParams({ cmd, api: currentApi, project: projectMatch[1] });
    appendLine('$ bash devtrace.sh project ' + projectMatch[1], 'line-cmd');
  } else if (readmeMatch) {
    cmd = 'portfolio';
    params = new URLSearchParams({ cmd, api: currentApi, project: readmeMatch[1], template: 'default' });
    appendLine('$ bash devtrace.sh portfolio ' + readmeMatch[1], 'line-cmd');
  } else if (interviewMatch) {
    cmd = 'interview';
    params = new URLSearchParams({ cmd, api: currentApi, project: interviewMatch[1] });
    appendLine('$ bash devtrace.sh interview ' + interviewMatch[1], 'line-cmd');
  } else {
    showToast('이 파일은 재생성을 지원하지 않습니다', 'error');
    return;
  }

  isRunning = true;
  const btn = document.getElementById('run-btn');
  btn.classList.add('running'); btn.disabled = true;

  try {
    const res = await fetch('/run?' + params);
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      const lines = buf.split('\n');
      buf = lines.pop();
      lines.forEach(l => appendLine(l, classifyLine(l)));
    }
  } catch(e) {
    appendLine('❌ ' + e.message, 'line-err');
  } finally {
    isRunning = false;
    btn.classList.remove('running'); btn.disabled = false;
    await loadResultFile(currentFilePath, currentFileName);
    showToast('재생성 완료', 'success');
  }
}

// ── 참고자료 모달 ─────────────────────────────────
function openRefModal() {
  document.getElementById('ref-modal').classList.add('show');
}
function closeRefModal() {
  document.getElementById('ref-modal').classList.remove('show');
  document.getElementById('url-list').innerHTML = `
    <div class="url-row">
      <input class="modal-input" type="text" placeholder="https://" />
      <button class="url-del-btn" onclick="removeUrl(this)">✕</button>
    </div>`;
  document.getElementById('file-list').textContent = '';
  selectedFiles = [];
}

function addUrl() {
  const list = document.getElementById('url-list');
  const row = document.createElement('div');
  row.className = 'url-row';
  row.innerHTML = `<input class="modal-input" type="text" placeholder="https://" /><button class="url-del-btn" onclick="removeUrl(this)">✕</button>`;
  list.appendChild(row);
}
function removeUrl(btn) {
  const rows = document.querySelectorAll('.url-row');
  if (rows.length > 1) btn.parentElement.remove();
  else btn.previousElementSibling.value = '';
}

function handleFileSelect(input) {
  selectedFiles = Array.from(input.files);
  document.getElementById('file-list').textContent =
    selectedFiles.map(f => '📄 ' + f.name).join('\n');
}
function handleFileDrop(e) {
  e.preventDefault();
  document.querySelector('.file-upload-area').classList.remove('dragover');
  selectedFiles = Array.from(e.dataTransfer.files);
  document.getElementById('file-list').textContent =
    selectedFiles.map(f => '📄 ' + f.name).join('\n');
}

async function submitRef() {
  if (!currentFilePath) return;
  const urls = Array.from(document.querySelectorAll('.url-row input'))
    .map(i => i.value.trim()).filter(Boolean);

  const formData = new FormData();
  formData.append('journal_path', currentFilePath);
  urls.forEach(u => formData.append('urls', u));
  selectedFiles.forEach(f => formData.append('files', f));

  try {
    const res = await fetch('/references', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.ok) {
      closeRefModal();
      showToast('📚 참고자료 저장 완료', 'success');
      await loadResultFile(currentFilePath, currentFileName);
    } else {
      showToast('❌ ' + data.error, 'error');
    }
  } catch(e) {
    showToast('❌ ' + e.message, 'error');
  }
}

// ── 템플릿 모달 ───────────────────────────────────
function openTmplModal() {
  document.getElementById('tmpl-modal').classList.add('show');
}
function closeTmplModal() {
  document.getElementById('tmpl-modal').classList.remove('show');
  document.getElementById('tmpl-name-input').value = '';
  document.getElementById('tmpl-content-input').value = '';
}

async function submitTemplate() {
  const name = document.getElementById('tmpl-name-input').value.trim();
  const content = document.getElementById('tmpl-content-input').value.trim();
  if (!name) { showToast('이름을 입력하세요', 'error'); return; }
  if (!content) { showToast('내용을 입력하세요', 'error'); return; }

  try {
    const res = await fetch('/templates/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, content })
    });
    const data = await res.json();
    if (data.ok) {
      closeTmplModal();
      // 드롭다운에 추가
      if (!TEMPLATES.includes(name)) {
        TEMPLATES.push(name);
        const sel = document.getElementById('input-template');
        if (sel) {
          const opt = document.createElement('option');
          opt.value = name; opt.textContent = name;
          sel.appendChild(opt);
          sel.value = name;
        }
      }
      showToast('📝 템플릿 저장 완료: ' + name, 'success');
    } else {
      showToast('❌ ' + data.error, 'error');
    }
  } catch(e) {
    showToast('❌ ' + e.message, 'error');
  }
}

// ── 커맨드 실행 ───────────────────────────────────
async function runCommand() {
  if (isRunning) return;
  const m = CMD_META[currentCmd];

  for (const key of m.inputs) {
    if (key === 'template') continue; // 선택 사항
    const val = getInputVal(key);
    if (!val) {
      showToast(INPUT_CONFIG[key].label + ' 값을 입력하세요', 'error');
      document.getElementById('input-' + key)?.focus();
      return;
    }
  }

  isRunning = true;
  const btn = document.getElementById('run-btn');
  btn.classList.add('running'); btn.disabled = true;

  // 편집 모드면 해제
  cancelEdit();

  document.getElementById('terminal').innerHTML = '';
  const now = new Date().toLocaleTimeString('ko-KR');
  document.getElementById('terminal-title').textContent = currentCmd + ' — ' + now;
  document.getElementById('result-view').innerHTML =
    '<div class="result-empty"><div class="ei">⏳</div><p>생성 중...</p></div>';
  document.getElementById('result-name').textContent = '생성 중...';

  // 액션 버튼 비활성화
  ['btn-edit','btn-ref','btn-regen'].forEach(id => document.getElementById(id).disabled = true);

  let cmdDisplay = '$ bash devtrace.sh ' + currentCmd;
  m.inputs.forEach(k => {
    if (k !== 'template') cmdDisplay += ' ' + getInputVal(k);
  });
  if (currentCmd === 'portfolio') {
    const t = getInputVal('template');
    if (t && t !== 'default') cmdDisplay += ' --template ' + t;
  }
  if (['daily','project','portfolio','interview','full','range','regenerate'].includes(currentCmd)) {
    if (currentApi !== 'groq') cmdDisplay += ' --api ' + currentApi;
  }
  appendLine(cmdDisplay, 'line-cmd');
  appendLine('', 'line-plain');

  const params = new URLSearchParams({ cmd: currentCmd, api: currentApi });
  m.inputs.forEach(k => { if (k !== 'template') params.set(k, getInputVal(k)); });
  if (currentCmd === 'portfolio') params.set('template', getInputVal('template') || 'default');

  try {
    const res = await fetch('/run?' + params);
    if (!res.ok) throw new Error('서버 오류: ' + res.status);
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      const lines = buf.split('\n');
      buf = lines.pop();
      lines.forEach(line => appendLine(line, classifyLine(line)));
    }
    if (buf) appendLine(buf, classifyLine(buf));
  } catch(e) {
    appendLine('❌ 오류: ' + e.message, 'line-err');
  } finally {
    isRunning = false;
    btn.classList.remove('running'); btn.disabled = false;
    appendLine('', 'line-plain');
    appendLine('─'.repeat(40), 'line-plain');
    await autoLoadResult();
    refreshJournals();
  }
}

// ── 결과 파일 자동 로드 ───────────────────────────
async function autoLoadResult() {
  const today = new Date().toISOString().slice(0, 10);
  const proj = getInputVal('project');
  let path = null, name = null;

  if (currentCmd === 'daily') {
    path = '{{ journal_dir }}/' + today + '.md'; name = today;
  } else if (currentCmd === 'weekly') {
    const now = new Date();
    const wk = String(Math.ceil(now.getDate() / 7)).padStart(2,'0');
    name = 'weekly_' + now.getFullYear() + '-W' + wk;
    path = '{{ journal_dir }}/' + name + '.md';
  } else if (currentCmd === 'full') {
    path = '{{ journal_dir }}/full_summary.md'; name = 'full_summary';
  } else if (currentCmd === 'range') {
    const f = getInputVal('from'), t = getInputVal('to');
    name = 'range_' + f + '_' + t;
    path = '{{ journal_dir }}/' + name + '.md';
  } else if (currentCmd === 'regenerate') {
    const d = getInputVal('date');
    path = '{{ journal_dir }}/' + d + '.md'; name = d;
  } else if (currentCmd === 'project') {
    path = '{{ journal_dir }}/project_' + proj + '.md'; name = 'project_' + proj;
  } else if (currentCmd === 'portfolio') {
    path = '{{ portfolio_dir }}/' + proj + '_README.md'; name = proj + '_README';
  } else if (currentCmd === 'interview') {
    path = '{{ portfolio_dir }}/' + proj + '_interview.md'; name = proj + '_interview';
  }

  if (path) await loadResultFile(path, name);
}

async function loadResultFile(path, name) {
  if (!path) return;
  try {
    const res = await fetch('/journal?path=' + encodeURIComponent(path));
    if (!res.ok) return;
    const text = await res.text();
    showResult(text, name, path);
  } catch(e) {}
}

async function refreshJournals() {
  try {
    const res = await fetch('/journals');
    const data = await res.json();
    const list = document.getElementById('journal-list');
    list.innerHTML = '';
    data.forEach(j => {
      const div = document.createElement('div');
      div.className = 'journal-item';
      div.onclick = () => loadJournal(j.path, j.name, div);
      div.innerHTML = `
        <div class="journal-dot"></div>
        <div class="journal-date" title="${j.name}">${j.name}</div>
        <div class="journal-size">${(j.size/1024).toFixed(1)}KB</div>`;
      list.appendChild(div);
    });
  } catch(e) {}
}

async function loadJournal(path, name, el) {
  document.querySelectorAll('.journal-item').forEach(i => i.classList.remove('active'));
  if (el) el.classList.add('active');
  try {
    const res = await fetch('/journal?path=' + encodeURIComponent(path));
    if (!res.ok) { showToast('파일 불러오기 실패', 'error'); return; }
    const text = await res.text();
    showResult(text, name, path);
  } catch(e) {
    showToast('오류: ' + e.message, 'error');
  }
}

function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + (type || '');
  setTimeout(() => { t.className = 'toast'; }, 2500);
}

// 초기화
renderInputs([]);
</script>
</body>
</html>"""


# ── Flask 라우트 ──────────────────────────────────────────────────────────────

@app.route("/")
def index():
    return render_template_string(
        HTML,
        journals=get_journals(),
        projects=get_projects(),
        templates=get_templates(),
        journal_dir=str(JOURNAL_DIR),
        portfolio_dir=str(PORTFOLIO_DIR),
    )


@app.route("/run")
def run():
    cmd = request.args.get("cmd", "daily")
    api = request.args.get("api", "groq")
    project  = request.args.get("project", "").strip()
    date_from = request.args.get("from", "").strip()
    date_to   = request.args.get("to", "").strip()
    date      = request.args.get("date", "").strip()
    template  = request.args.get("template", "default").strip()

    allowed = {"daily","weekly","full","range","regenerate","project","portfolio","interview","push","status"}
    if cmd not in allowed:
        return Response("허용되지 않는 명령어", status=400)

    args = ["bash", DEVTRACE_SH, cmd]

    if cmd == "range":
        if date_from: args.append(date_from)
        if date_to:   args.append(date_to)
    elif cmd == "regenerate":
        if date: args.append(date)
    elif cmd in ("project", "portfolio", "interview") and project:
        args.append(project)

    if cmd == "portfolio" and template and template != "default":
        args += ["--template", template]

    if api in ("groq", "openai") and cmd in ("daily","project","portfolio","interview","full","range","regenerate"):
        args += ["--api", api]

    def generate():
        try:
            proc = subprocess.Popen(
                args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, bufsize=1, cwd=str(DEVTRACE_DIR),
            )
            for line in iter(proc.stdout.readline, ""):
                yield line
            proc.wait()
            yield "\n✅ 완료\n" if proc.returncode == 0 else f"\n⚠️  종료 코드: {proc.returncode}\n"
        except Exception as e:
            yield f"❌ 실행 오류: {e}\n"

    return Response(stream_with_context(generate()), mimetype="text/plain",
                    headers={"X-Accel-Buffering": "no"})


@app.route("/journals")
def journals():
    return jsonify(get_journals())


@app.route("/journal")
def journal():
    path = request.args.get("path", "")
    p = Path(path)
    allowed_dirs = [str(JOURNAL_DIR), str(PORTFOLIO_DIR)]
    if not p.exists() or not any(str(p).startswith(d) for d in allowed_dirs):
        return "파일 없음", 404
    return p.read_text(encoding="utf-8"), 200, {"Content-Type": "text/plain; charset=utf-8"}


@app.route("/save", methods=["POST"])
def save():
    """편집한 일지 저장"""
    data = request.get_json()
    path = data.get("path", "")
    content = data.get("content", "")
    p = Path(path)
    allowed_dirs = [str(JOURNAL_DIR), str(PORTFOLIO_DIR)]
    if not any(str(p).startswith(d) for d in allowed_dirs):
        return jsonify({"ok": False, "error": "허용되지 않는 경로"})
    try:
        p.write_text(content, encoding="utf-8")
        return jsonify({"ok": True})
    except Exception as e:
        return jsonify({"ok": False, "error": str(e)})


@app.route("/references", methods=["POST"])
def references():
    """참고자료 저장 — URL + 파일"""
    journal_path = request.form.get("journal_path", "")
    urls = request.form.getlist("urls")
    files = request.files.getlist("files")

    jp = Path(journal_path)
    allowed_dirs = [str(JOURNAL_DIR), str(PORTFOLIO_DIR)]
    if not jp.exists() or not any(str(jp).startswith(d) for d in allowed_dirs):
        return jsonify({"ok": False, "error": "허용되지 않는 경로"})

    today = datetime.now().strftime("%Y-%m-%d")
    ref_dir = REFERENCES_DIR / today
    ref_dir.mkdir(parents=True, exist_ok=True)

    saved_items = []

    # 파일 저장
    for f in files:
        if f.filename:
            dest = ref_dir / f.filename
            f.save(str(dest))
            saved_items.append(f"- 📄 {f.filename}")

    # URL 저장
    for url in urls:
        if url.strip():
            saved_items.append(f"- 🌐 {url.strip()}")

    if not saved_items:
        return jsonify({"ok": False, "error": "저장할 항목이 없습니다"})

    # 일지에 섹션 추가
    try:
        content = jp.read_text(encoding="utf-8")
        if "## 📚 참고 자료" not in content:
            content += "\n\n## 📚 참고 자료\n"
        content += "\n".join(saved_items) + "\n"
        jp.write_text(content, encoding="utf-8")
        return jsonify({"ok": True})
    except Exception as e:
        return jsonify({"ok": False, "error": str(e)})


@app.route("/templates/save", methods=["POST"])
def save_template():
    """커스텀 템플릿 저장"""
    data = request.get_json()
    name = data.get("name", "").strip()
    content = data.get("content", "").strip()

    # 파일명 안전하게
    safe_name = "".join(c for c in name if c.isalnum() or c in "-_")
    if not safe_name:
        return jsonify({"ok": False, "error": "유효하지 않은 이름"})

    try:
        path = TEMPLATES_DIR / f"{safe_name}.md"
        path.write_text(content, encoding="utf-8")
        return jsonify({"ok": True, "name": safe_name})
    except Exception as e:
        return jsonify({"ok": False, "error": str(e)})


